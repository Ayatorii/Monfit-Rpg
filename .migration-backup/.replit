modules = ["nodejs-24", "python-base-3.13", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
VITE_WALLETCONNECT_PROJECT_ID = "2d05c2faf4b5da282159b462f1babcbb"
CURRENT_SEASON = "1"
MINT_ADMIN_SECRET = "monfit-s1-mint-2026"
SEASON_TROPHY_ADDRESS = "0xBe28F09078C9D55432cddEFB3Ebd0D18F8b1cEe6"
VITE_TROPHY_CONTRACT_ADDRESS = "0xBe28F09078C9D55432cddEFB3Ebd0D18F8b1cEe6"
