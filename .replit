modules = ["nodejs-24", "postgresql-16"]

[[ports]]
localPort = 8080
externalPort = 80

[[ports]]
localPort = 26223
externalPort = 3000

[deployment]
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

# "Project" starts both managed artifact services in parallel.
# Do NOT add manual shell.exec tasks for api-server or monfit-rpg here —
# the artifact-managed workflows already inject PORT, BASE_PATH, and proxy routing.
[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "artifacts/api-server: API Server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "artifacts/monfit-rpg: web"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 60000

[nix]
channel = "stable-25_05"
