modules = ["nodejs-20", "python-3.12", "web", "postgresql-16"]

[[ports]]
localPort = 8080
externalPort = 80

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 9999
externalPort = 3001

[[ports]]
localPort = 26223
externalPort = 3000

[deployment]
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

# "Project" starts both services in parallel.
# - "API Server" — Express backend on port 8080
# - "Monfit RPG Frontend" — Vite dev server on port 26223 (proxies /api -> localhost:8080)
[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "API Server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Monfit RPG Frontend"

[[workflows.workflow]]
name = "API Server"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm install && PORT=8080 pnpm --filter @workspace/api-server run dev"
waitForPort = 8080

[[workflows.workflow]]
name = "Monfit RPG Frontend"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm install && BASE_PATH=/ PORT=26223 pnpm --filter @workspace/monfit-rpg run dev"
waitForPort = 26223

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 60000

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
CURRENT_SEASON = "1"
SEASON_TROPHY_ADDRESS = "0xbe28f09078c9d55432cddefb3ebd0d18f8b1cee6"
VITE_TROPHY_CONTRACT_ADDRESS = "0xbe28f09078c9d55432cddefb3ebd0d18f8b1cee6"
ACHIEVEMENT_BADGE_ADDRESS = "0x5DD439654C279423696254f52e30c7456689c88F"
